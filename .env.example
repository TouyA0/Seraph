# ── IA ────────────────────────────────────────────────────────────────────────
# Ollama (défaut, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Endpoint OpenAI-compatible alternatif (laisser vide pour Ollama)
# OPENAI_COMPATIBLE_URL=
# OPENAI_COMPATIBLE_KEY=

# Désactiver l'IA complètement
AI_ENABLED=true

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=3600

# ── Sources gratuites (sans clé) ──────────────────────────────────────────────
# Ces sources fonctionnent immédiatement, aucune clé requise.

# ── Sources clé gratuite ──────────────────────────────────────────────────────
# Obtenir sur : https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# Obtenir sur : https://threatfox.abuse.ch/api/ (gratuit)
THREATFOX_API_KEY=

# Obtenir sur : https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# Obtenir sur : https://otx.alienvault.com/api
OTX_API_KEY=

# Obtenir sur : https://urlscan.io/user/signup
URLSCAN_API_KEY=

# Obtenir sur : https://censys.io/register
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── Sources payantes (optionnelles) ───────────────────────────────────────────
# Obtenir sur : https://account.shodan.io
SHODAN_API_KEY=

# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Mode OSINT passif uniquement (ne soumet jamais l'artefact à un service actif)
PASSIVE_MODE=false

# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/seraph.db
